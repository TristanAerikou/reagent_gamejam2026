[sub_resource type="GDScript" id="GDScript_gubc5"]
script/source = "extends Timer

const order_template = preload(\"res://scenes/order.tscn\")

func _ready() -> void:
	_on_timeout()

func _on_timeout() -> void:
	var order := order_template.instantiate()
	%Orders.add_child.call_deferred(order)
	order.timeout.connect(%Player.die)
	if wait_time > 0.25:
		wait_time -= 0.25
"

